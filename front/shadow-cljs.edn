{:source-paths ["src"]
 :dependencies [[re-frame "1.3.0"]
                [reagent "1.2.0"]]
 :dev-http {8280 "public"}
 :builds
 {:app {:target :browser
        :output-dir "public/js"
        :asset-path "/js"
        :modules {:main {:init-fn main.app/init}}
        :devtools {:after-load main.app/reload!}}}}